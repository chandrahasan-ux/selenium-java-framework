<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Wikipedia Automation Suite" verbose="1" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="utils.ExtentReportListener"/>
    </listeners>

    <test name="Home Page Tests">
        <classes>
            <class name="tests.HomePageTest"/>
        </classes>
    </test>

    <test name="Search Functionality Tests">
        <classes>
            <class name="tests.SearchTest"/>
        </classes>
    </test>

</suite>
